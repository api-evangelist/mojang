      "id": "0c52fe05-34d7-40d0-91bc-1978dce9b7b2",
      "name": "Session",
      "description": {
        "content": "Login-handshake session verification",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "37d705b0-2183-415e-9dd6-f15ef1bbc98b",
          "name": "Has Joined Verification (Server-Side)",
          "request": {
            "name": "Has Joined Verification (Server-Side)",
            "description": {
              "content": "Called by a Minecraft server during the login handshake to verify that the client claiming to be `username` has authenticated against Mojang for the supplied `serverId` (a SHA-1 hash of the server's shared secret and public key). Returns the player's full session profile on success.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "session",
                "minecraft",
                "hasJoined"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "username",
                  "value": "<string>",
                  "description": "(Required) Username sent by the connecting client."
                },
                {
                  "disabled": false,
                  "key": "serverId",
                  "value": "<string>",
                  "description": "(Required) SHA-1 server hash computed during the handshake."
                },
                {
                  "disabled": false,
                  "key": "ip",
                  "value": "<string>",
                  "description": "Optional IP of the connecting client for stricter checks."
                },
                {
                  "disabled": false,
                  "key": "prevent_proxy",
                  "value": "<boolean>",
                  "description": "When true, fails verification if the client appears proxied."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
