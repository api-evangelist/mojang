        {
          "id": "79a9df18-0ecd-4634-8bb4-b38ff9199dce",
          "name": "Get Session Profile (Skin and Cape)",
          "request": {
            "name": "Get Session Profile (Skin and Cape)",
            "description": {
              "content": "Returns the player's session profile including the Base64-encoded textures property holding skin and cape URLs. Pass unsigned=false to receive a signed payload that includes Mojang's RSA signature.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "session",
                "minecraft",
                "profile",
                ":uuid"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "unsigned",
                  "value": "<boolean>",
                  "description": "Set to false to include the Mojang signature on each property. When omitted, properties are returned without signature."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "uuid",
                  "description": "(Required) Player UUID (hyphenated or unhyphenated)."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
